{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "types": ["astro/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.astro", "example/**/*.ts", "example/**/*.astro"]
}
