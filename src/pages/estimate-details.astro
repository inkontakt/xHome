---
import Layout from '@/layouts/Layout.astro'
import ImageGallery from '@/components/estimate-details/image-gallery'
import PdfViewer from '@/components/estimate-details/pdf-viewer'
import { loadEstimateData } from '@/lib/estimate-data'
import { safeDownloadFileName } from '@/lib/estimate-files'

const tenantParam = Astro.url.searchParams.get('tenant')?.trim() || Astro.url.searchParams.get('tenant_id')?.trim() || ''
const estimateId = Astro.url.searchParams.get('estimate_id')?.trim() || ''
const hasRequiredQuery = tenantParam.length > 0 && estimateId.length > 0
const estimateData = await loadEstimateData(tenantParam, estimateId)
const person = estimateData.person
const pdfFile = estimateData.pdfFile
const imageFiles = estimateData.imageFiles
const greeting = person?.last_name ? `Hallo Herr ${person.last_name},` : 'Hallo there'
const tenantLabel = hasRequiredQuery && estimateData.status !== 'missing-config' ? estimateData.tenant?.name ?? null : null

const pageTitle = 'Estimate Details | Orion'
const pageDescription =
  'View estimate download details and related damage images with preserved tenant and estimate query parameters.'
const pdfPreviewUrl = pdfFile?.file_url
  ? `/api/pdf?${new URLSearchParams({ url: pdfFile.file_url }).toString()}`
  : null
const pdfDownloadUrl =
  pdfFile?.file_url && pdfPreviewUrl
    ? `${pdfPreviewUrl}&download=1&filename=${encodeURIComponent(safeDownloadFileName(pdfFile.file_name, 'PDF Preview.pdf'))}`
    : null
const imageEmptyMessage =
  estimateData.status === 'missing-config'
    ? 'Supabase is not configured for this Astro app yet.'
    : estimateData.status === 'not-found'
      ? 'No estimate images were found for these IDs.'
      : estimateData.status === 'error'
        ? estimateData.message
        : 'Image thumbnails will appear here once linked to this estimate.'
---

<Layout title={pageTitle} description={pageDescription} noindex={true}>
  <section class='px-5 py-6 sm:px-5 sm:py-8'>
    <div class='mx-auto w-full max-w-none'>
      <div class='space-y-6'>
        <header class='space-y-2 text-center'>
          <p class='text-[35px] leading-tight tracking-wide text-foreground'>
            Angebot und Schadensbilder zum Download
          </p>
          <h1 class='text-3xl font-semibold tracking-tight'>{greeting}</h1>
          <p class='mx-auto max-w-3xl text-[20px] leading-relaxed text-muted-foreground'>
            Hier finden Sie Ihr Angebot zum Download inklusive der Schadensbilder.
          </p>
        </header>

        <div class='grid w-full items-start gap-6 md:grid-cols-2'>
          <section class='rounded-lg border bg-background p-4 shadow-sm'>
            {
              pdfFile?.file_url && (
                <div class='mb-4 flex items-center justify-between gap-3'>
                  <div class='flex items-center gap-3'>
                    <h2 class='text-lg font-semibold'>PDF Preview</h2>
                    {tenantLabel && <span class='text-xs text-muted-foreground'>{tenantLabel}</span>}
                  </div>
                  <a
                    href={pdfDownloadUrl}
                    target='_blank'
                    rel='noreferrer'
                    class='rounded-md border bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition hover:bg-primary/90'
                  >
                    Download
                  </a>
                </div>
              )
            }
            <div class='rounded-md border border-dashed p-4'>
              {
                pdfFile?.file_url ? (
                  <PdfViewer client:load url={pdfFile.file_url} />
                ) : (
                  <div class='flex min-h-[360px] items-center justify-center px-4 text-center text-sm text-muted-foreground md:min-h-[600px]'>
                    {estimateData.status === 'missing-query'
                      ? 'PDF content will render here once connected.'
                      : estimateData.status === 'missing-config'
                        ? 'Supabase is not configured for this Astro app yet.'
                        : estimateData.status === 'not-found'
                          ? 'No estimate was found for these tenant and estimate values.'
                          : estimateData.status === 'error'
                            ? estimateData.message
                            : 'No PDF uploaded for this estimate yet.'}
                  </div>
                )
              }
            </div>
            <p class='mt-3 text-xs text-muted-foreground'>This area embeds the PDF file linked to the submission.</p>
            {
              pdfFile?.file_url && (
                <div class='mt-4 flex justify-center'>
                  <a
                    href={pdfDownloadUrl}
                    target='_blank'
                    rel='noreferrer'
                    class='rounded-md border bg-primary px-6 py-3 text-base font-semibold text-primary-foreground transition hover:bg-primary/90'
                  >
                    Download
                  </a>
                </div>
              )
            }
          </section>

          <ImageGallery
            client:load
            imageFiles={imageFiles}
            contextLabel={tenantLabel}
            emptyMessage={imageEmptyMessage}
          />
        </div>
      </div>
    </div>
  </section>
</Layout>
