---
import Layout from '@/layouts/Layout.astro'
import HeroSection from '@/components/sections/hero-section'
import FeaturesSection from '@/components/sections/features-section'
import WorksFeaturesSectionPage from '@/components/sections/works-features-section'
import UseCasesSection from '@/components/sections/use-cases-section'
import TestimonialsSection from '@/components/sections/testimonials-section'
import PricingSectionPage from '@/components/sections/pricing-section'
import FAQSectionPage from '@/components/sections/faq-section'
import CTASection from '@/components/sections/cta-section'
import FooterSection from '@/components/sections/footer-section'
import StandaloneBookingSection from '@/components/sections/standalone-booking-section.astro'
import StandaloneFormProxySection from '@/components/sections/standalone-form-proxy-section.astro'
import DynamicFormRenderer from '@/components/forms/DynamicFormRenderer'
import { loadLandingContent } from '@/lib/loaders/landing-sections-loader'

const landing = await loadLandingContent()

const pageTitle = landing.seo.title
const pageDescription = landing.seo.description
const pageKeywords = landing.seo.keywords
const formId = landing.integrations?.formId
const proxyFormId = landing.integrations?.proxyFormId
const bookingCalendarId = landing.integrations?.bookingCalendarId
const bookingEventId = landing.integrations?.bookingEventId
const hasStandaloneBooking = Boolean(bookingCalendarId && bookingEventId)
const forwardedSearch = Astro.url.search

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      '@id': `${Astro.site}#website`,
      name: landing.seo.siteName,
      description: pageDescription,
      url: `${Astro.site}`,
      inLanguage: 'en-US'
    }
  ]
}
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} schema={schema}>
  <HeroSection content={landing.hero} client:load />
  <FeaturesSection content={landing.features} client:load />
  <WorksFeaturesSectionPage content={landing.worksFeatures} client:load />
  <UseCasesSection content={landing.useCases} client:load />
  <TestimonialsSection content={landing.testimonials} client:load />
  <PricingSectionPage content={landing.pricing} client:load />
  <FAQSectionPage content={landing.faq} client:load />
  <CTASection content={landing.cta} client:load />
  {formId ? (
    <DynamicFormRenderer
      formId={formId}
      bookingCalendarId={bookingCalendarId}
      bookingEventId={bookingEventId}
      client:load
    />
  ) : null}
  {hasStandaloneBooking ? (
    <StandaloneBookingSection
      calendarId={bookingCalendarId!}
      eventId={bookingEventId!}
      forwardedSearch={forwardedSearch}
    />
  ) : null}
  {proxyFormId ? (
    <StandaloneFormProxySection formId={proxyFormId} forwardedSearch={forwardedSearch} />
  ) : null}
  <FooterSection content={landing.footer} newsletter={true} client:load />
</Layout>
