---
import {
  BadgeCheck,
  CircleDollarSign,
  Headset,
  Laptop2,
  PaintbrushVertical,
  ShieldCheck,
  Sparkles,
  Stars,
  Wrench
} from 'lucide-react'

import { carfitHamburg2About, carfitHamburg2Differentiators } from '@/components/carfit-hamburg-2/carfit-hamburg-2-data'

const icons = [
  Stars,
  Sparkles,
  ShieldCheck,
  Wrench,
  Laptop2,
  CircleDollarSign,
  BadgeCheck,
  PaintbrushVertical,
  Headset,
  Stars,
  Wrench,
  ShieldCheck
]
---

<section class='relative overflow-hidden bg-[var(--carfit-dark)] py-16 text-white sm:py-20'>
  <div class='absolute inset-0 bg-[linear-gradient(180deg,rgba(14,22,36,0.92),rgba(14,22,36,0.96))]'></div>
  <div class='relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8'>
    <div class='mx-auto max-w-3xl text-center'>
      <h2 class='text-3xl font-semibold tracking-tight sm:text-4xl'>Was macht uns besonders?</h2>
    </div>
    <div class='mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4'>
      {carfitHamburg2Differentiators.map((item, index) => {
        const Icon = icons[index % icons.length]

        return (
          <article class='rounded-lg border border-white/10 bg-white/5 p-4'>
            <span class='inline-flex size-10 items-center justify-center rounded-full bg-white/10 text-sky-300'>
              <Icon className='size-5' />
            </span>
            <h3 class='mt-3 text-base font-semibold'>{item.title}</h3>
            <p class='mt-2 text-xs leading-5 text-white/70'>{item.description}</p>
          </article>
        )
      })}
    </div>
    <div class='mt-8 text-center'>
      <a
        href='#online-anfrage'
        class='inline-flex items-center rounded-md bg-[var(--carfit-accent)] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[var(--carfit-accent-strong)]'
      >
        Hier Preis anfragen
      </a>
    </div>
  </div>
</section>

<section class='bg-white py-14 sm:py-18'>
  <div class='mx-auto grid max-w-6xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-center lg:px-8'>
    <div class='flex justify-center lg:justify-start'>
      <div class='relative w-full max-w-xs'>
        <div class='relative overflow-hidden rounded-2xl bg-gradient-to-b from-slate-100 to-slate-50 p-6 shadow-lg'>
          <div class='relative mx-auto flex h-72 w-48 flex-col items-center justify-end'>
            <div class='absolute -top-4 left-1/2 h-24 w-24 -translate-x-1/2 rounded-full bg-gradient-to-b from-amber-100 via-amber-200 to-amber-300 shadow-lg'>
              <div class='absolute left-1/2 top-6 h-3 w-8 -translate-x-1/2 rounded bg-slate-800'></div>
              <div class='absolute left-1/2 top-12 h-2 w-4 -translate-x-1/2 rounded-full bg-amber-400'></div>
              <div class='absolute left-1/2 top-16 h-1 w-6 -translate-x-1/2 rounded bg-red-300'></div>
            </div>
            <div class='relative z-10 -mt-6'>
              <div class='mx-auto h-40 w-36 rounded-t-xl bg-gradient-to-b from-slate-800 via-slate-900 to-slate-950'>
                <div class='absolute left-1/2 top-4 h-24 w-12 -translate-x-1/2 rounded-sm bg-white'></div>
                <div class='absolute left-1/2 top-6 h-16 w-1 -translate-x-1/2 bg-[var(--carfit-accent)]'></div>
                <div class='absolute left-1/2 top-[5.5rem] h-2 w-3 -translate-x-1/2 rounded-sm bg-[var(--carfit-accent)]'></div>
                <div class='absolute left-4 top-12 h-20 w-4 rounded-full bg-gradient-to-b from-amber-200 to-amber-300'></div>
                <div class='absolute right-4 top-12 h-20 w-4 rounded-full bg-gradient-to-b from-amber-200 to-amber-300'></div>
              </div>
            </div>
          </div>
          <div class='mt-4 rounded-xl border border-slate-200 bg-white p-3 text-center'>
            <p class='text-xs font-semibold uppercase tracking-[0.15em] text-[var(--carfit-accent)]'>Peter Bock</p>
            <p class='mt-1 text-sm font-semibold text-slate-900'>Geschäftsführer</p>
          </div>
        </div>
      </div>
    </div>

    <div>
      <p class='text-sm font-semibold uppercase tracking-[0.28em] text-[var(--carfit-accent)]'>{carfitHamburg2About.sectionLabel}</p>
      <h2 class='mt-4 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl'>{carfitHamburg2About.heading}</h2>
      <p class='mt-4 text-lg font-medium text-[var(--carfit-accent)]'>{carfitHamburg2About.intro}</p>
      <div class='mt-5 space-y-4'>
        {carfitHamburg2About.body.map(paragraph => (
          <p class='text-sm leading-7 text-slate-600 sm:text-base'>{paragraph}</p>
        ))}
      </div>
      <div class='mt-7 flex flex-wrap items-center gap-4'>
        <a
          href='#online-anfrage'
          class='inline-flex items-center rounded-md bg-[var(--carfit-accent)] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[var(--carfit-accent-strong)]'
        >
          {carfitHamburg2About.ctaLabel}
        </a>
        <a
          href='https://maps.google.com/?q=Fangdieckstra%C3%9Fe+32,+22547+Hamburg'
          target='_blank'
          rel='noreferrer'
          class='text-sm font-semibold text-slate-600 transition hover:text-slate-950'
        >
          {carfitHamburg2About.mapLabel}
        </a>
      </div>
    </div>
  </div>
</section>
