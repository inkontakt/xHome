---
import { Star } from 'lucide-react'

import { carfitHamburg2Reviews } from '@/components/carfit-hamburg-2/carfit-hamburg-2-data'
---

<section class='bg-[var(--carfit-pink)] py-14 sm:py-18'>
  <div class='mx-auto max-w-6xl px-4 sm:px-6 lg:px-8'>
    <div class='text-center'>
      <h2 class='text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl'>
        {carfitHamburg2Reviews.heading}
      </h2>
      <div class='mt-4 flex items-center justify-center gap-2'>
        <div class='flex items-center gap-0.5'>
          {[1, 2, 3, 4, 5].map(() => (
            <Star className='size-5 fill-amber-400 text-amber-400' />
          ))}
        </div>
        <span class='text-2xl font-bold text-slate-900'>{carfitHamburg2Reviews.summaryScore}</span>
      </div>
      <p class='mt-2 text-sm text-slate-600'>{carfitHamburg2Reviews.summaryText}</p>
    </div>

    <div class='mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4'>
      {carfitHamburg2Reviews.items.map(review => (
        <article class='rounded-lg border border-slate-200 bg-white p-3 shadow-sm'>
          <div class='flex items-center gap-2'>
            <div
              class='flex size-8 shrink-0 items-center justify-center rounded-full text-sm font-semibold text-white'
              style={`background-color: ${review.color}`}
            >
              {review.name.charAt(0).toUpperCase()}
            </div>
            <div class='min-w-0 flex-1'>
              <p class='truncate text-xs font-semibold text-slate-900'>{review.name}</p>
              <p class='text-[10px] text-slate-500'>{review.date}</p>
            </div>
          </div>
          <div class='mt-2 flex items-center gap-0.5'>
            {[1, 2, 3, 4, 5].map(() => (
              <Star className='size-3 fill-amber-400 text-amber-400' />
            ))}
          </div>
          <p class='mt-2 line-clamp-3 text-xs leading-5 text-slate-600'>{review.text}</p>
        </article>
      ))}
    </div>

    <div class='mt-6 text-center'>
      <a
        href='#online-anfrage'
        class='inline-flex items-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50'
      >
        {carfitHamburg2Reviews.ctaLabel}
      </a>
    </div>
  </div>
</section>
