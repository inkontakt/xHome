---
import { BriefcaseBusiness, Facebook, Instagram, Mail, MapPinned, Send, Smartphone } from 'lucide-react'

import { carfitContact, carfitFooterLinks, carfitForm } from '@/components/carfit/carfit-data'
---

<section class='border-y border-slate-200 bg-slate-50 py-3'>
  <div class='mx-auto flex max-w-6xl items-center justify-center gap-2 px-4 text-sm font-semibold text-slate-600 sm:px-6 lg:px-8'>
    <MapPinned className='size-4 text-[var(--carfit-accent)]' />
    <span>Karte anzeigen</span>
  </div>
</section>

<section id='online-anfrage' class='bg-white py-16 sm:py-20'>
  <div class='mx-auto max-w-4xl px-4 sm:px-6 lg:px-8'>
    <div class='text-center'>
      <h2 class='mt-4 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl'>{carfitForm.heading}</h2>
      <p class='mx-auto mt-4 max-w-2xl text-sm leading-7 text-slate-600 sm:text-base'>{carfitForm.intro}</p>
    </div>

    <form class='mt-10 grid gap-4 rounded-[2rem] border border-slate-200 bg-slate-50/70 p-6 shadow-[0_16px_40px_rgba(15,23,42,0.06)] sm:grid-cols-2 sm:p-8'>
      <label class='sm:col-span-2'>
        <span class='mb-2 block text-sm font-medium text-slate-700'>Firmenname</span>
        <input class='w-full rounded-full border border-sky-100 bg-white px-4 py-3 text-sm outline-none transition focus:border-[var(--carfit-accent)]' placeholder='Firmenname' />
      </label>
      <label>
        <span class='mb-2 block text-sm font-medium text-slate-700'>Vorname</span>
        <input class='w-full rounded-full border border-sky-100 bg-white px-4 py-3 text-sm outline-none transition focus:border-[var(--carfit-accent)]' placeholder='Vorname' />
      </label>
      <label>
        <span class='mb-2 block text-sm font-medium text-slate-700'>Nachname</span>
        <input class='w-full rounded-full border border-sky-100 bg-white px-4 py-3 text-sm outline-none transition focus:border-[var(--carfit-accent)]' placeholder='Nachname' />
      </label>
      <label>
        <span class='mb-2 block text-sm font-medium text-slate-700'>Telefonnummer</span>
        <input class='w-full rounded-full border border-sky-100 bg-white px-4 py-3 text-sm outline-none transition focus:border-[var(--carfit-accent)]' placeholder='Mobilnummer' />
      </label>
      <label>
        <span class='mb-2 block text-sm font-medium text-slate-700'>Emailadresse</span>
        <input class='w-full rounded-full border border-sky-100 bg-white px-4 py-3 text-sm outline-none transition focus:border-[var(--carfit-accent)]' placeholder='Ihre beste Emailadresse' />
      </label>
      <label>
        <span class='mb-2 block text-sm font-medium text-slate-700'>Wie sind Sie auf uns aufmerksam geworden?</span>
        <select class='w-full rounded-full border border-sky-100 bg-white px-4 py-3 text-sm outline-none transition focus:border-[var(--carfit-accent)]'>
          <option>Bitte treffen Sie eine Auswahl</option>
          {carfitForm.referralOptions.map(option => (
            <option>{option}</option>
          ))}
        </select>
      </label>
      <label>
        <span class='mb-2 block text-sm font-medium text-slate-700'>Wie können wir Ihnen helfen?</span>
        <select class='w-full rounded-full border border-sky-100 bg-white px-4 py-3 text-sm outline-none transition focus:border-[var(--carfit-accent)]'>
          <option>Bitte auswählen</option>
          {carfitForm.serviceOptions.map(option => (
            <option>{option}</option>
          ))}
        </select>
      </label>
      <label class='sm:col-span-2'>
        <span class='mb-2 block text-sm font-medium text-slate-700'>Ihre Nachricht an das Carfit Team</span>
        <textarea class='min-h-36 w-full rounded-[1.25rem] border border-sky-100 bg-white px-4 py-3 text-sm outline-none transition focus:border-[var(--carfit-accent)]' placeholder='Beschreiben Sie Ihr Anliegen so konkret wie möglich.'></textarea>
      </label>
      <label class='sm:col-span-2'>
        <span class='mb-2 block text-sm font-medium text-slate-700'>Haben Sie Bilder zur Veranschaulichung?</span>
        <input type='file' class='block w-full rounded-[1.25rem] border border-dashed border-sky-200 bg-white px-4 py-4 text-sm text-slate-500' />
      </label>
      <label class='sm:col-span-2 flex items-start gap-3 rounded-[1.25rem] border border-slate-200 bg-white p-4 text-sm leading-6 text-slate-600'>
        <input type='checkbox' class='mt-1 size-4 rounded border-slate-300 text-[var(--carfit-accent)]' />
        <span>Ich akzeptiere die nachfolgende Datenschutzerklärung und den Informationsvertrag.</span>
      </label>
      <div class='sm:col-span-2 flex flex-wrap items-center justify-between gap-4'>
        <p class='text-xs leading-6 text-slate-500'>Die Formularstruktur bildet den sichtbaren Anfragebereich des Referenzlayouts nach.</p>
        <button type='button' class='inline-flex items-center gap-2 rounded-md bg-[var(--carfit-accent)] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[var(--carfit-accent-strong)]'>
          <Send className='size-4' />
          Absenden
        </button>
      </div>
    </form>
  </div>
</section>

<footer class='bg-[var(--carfit-footer)] py-12 text-white'>
  <div class='mx-auto grid max-w-6xl gap-8 px-4 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8'>
    <div>
      <h3 class='text-lg font-semibold'>Social Media</h3>
      <div class='mt-4 flex flex-wrap items-center gap-2'>
        {carfitFooterLinks.map(link => {
          const Icon =
            link.label === 'Facebook' ? Facebook : link.label === 'Instagram' ? Instagram : BriefcaseBusiness

          return (
            <a
              href={link.href}
              target='_blank'
              rel='noreferrer'
              aria-label={link.label}
              class='inline-flex size-8 items-center justify-center rounded-sm bg-white text-[var(--carfit-footer)] transition hover:opacity-90'
            >
              <Icon className='size-4' />
            </a>
          )
        })}
      </div>
      <div class='mt-6 space-y-2 text-sm text-white/72'>
        <p class='flex items-center gap-2'><Smartphone className='size-4' /> {carfitContact.phoneDisplay}</p>
        <p class='flex items-center gap-2'><Mail className='size-4' /> {carfitContact.email}</p>
        <p class='flex items-center gap-2'><MapPinned className='size-4' /> {carfitContact.addressLines.join(', ')}</p>
      </div>
      <p class='mt-6 text-xs uppercase tracking-[0.16em] text-white/55'>Alle Rechte vorbehalten | Carfit-Hamburg © 2026</p>
      <div class='mt-3 flex flex-wrap items-center gap-3 text-xs text-white/72'>
        <a href='#' class='transition hover:text-white'>Impressum</a>
        <a href='#' class='transition hover:text-white'>Datenschutz</a>
        <span>Cookie-Einstellungen</span>
      </div>
    </div>

    <div class='justify-self-start rounded-sm bg-white px-5 py-4 text-slate-900 shadow-xl lg:justify-self-end'>
      <p class='text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-500'>ProvenExpert</p>
      <div class='mt-2 flex h-32 w-28 items-center justify-center text-center'>
        <div>
          <p class='mt-2 text-3xl font-bold text-amber-500'>4.8</p>
          <p class='mt-1 text-xs uppercase tracking-[0.2em] text-slate-500'>Top bewertet</p>
          <p class='mt-2 text-[11px] leading-5 text-slate-600'>Mehr Infos</p>
        </div>
      </div>
    </div>
  </div>
</footer>
