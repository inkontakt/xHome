---
import { CheckCircle2, Sparkles } from 'lucide-react'

import { carfitBenefits, carfitServices } from '@/components/carfit/carfit-data'
---

<section class='bg-white py-14 sm:py-18'>
  <div class='mx-auto max-w-6xl px-4 sm:px-6 lg:px-8'>
    <div class='grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center'>
      <div>
        <p class='text-sm font-semibold uppercase tracking-[0.28em] text-[var(--carfit-accent)]'>Warum zu Carfit?</p>
        <h2 class='mt-4 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl'>
          Wir sorgen für das einwandfreie Erscheinungsbild Ihres Fahrzeugs
        </h2>
        <div class='mt-6 space-y-4'>
          {carfitBenefits.map(item => (
            <div class='flex gap-3 text-slate-600'>
              <CheckCircle2 className='mt-1 size-5 shrink-0 text-[var(--carfit-accent)]' />
              <p class='text-sm leading-7 sm:text-base'>{item}</p>
            </div>
          ))}
        </div>
      </div>

      <div class='flex justify-center lg:justify-end'>
        <div class='relative w-full max-w-sm overflow-hidden rounded-sm bg-[var(--carfit-light)] p-8 shadow-[0_18px_36px_rgba(37,99,235,0.1)]'>
          <div class='relative mx-auto flex h-80 w-60 flex-col items-center justify-end rounded-[1.25rem] bg-[linear-gradient(180deg,#99c6ff_0%,#5b8fee_35%,#2c4ca5_70%,#14213a_100%)] px-6 pb-8'>
            <div class='absolute top-10 flex size-24 items-center justify-center rounded-full bg-white text-[var(--carfit-accent)] shadow-xl'>
              <Sparkles className='size-10' />
            </div>
            <div class='w-full rounded-[1rem] border border-white/25 bg-white/12 p-4 text-center backdrop-blur-sm'>
              <p class='text-sm font-semibold uppercase tracking-[0.2em] text-white/70'>CARFIT Team</p>
              <p class='mt-2 text-lg font-semibold text-white'>Fachkundig. Sorgfältig. Hamburg.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class='mt-14 grid gap-5 sm:grid-cols-2 xl:grid-cols-3'>
      {carfitServices.map(service => (
        <article class='overflow-hidden rounded-sm border border-slate-200 bg-white shadow-[0_12px_26px_rgba(15,23,42,0.08)]'>
          <div class={`relative h-52 bg-gradient-to-br ${service.accent}`}>
            <div class='absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.04),rgba(15,23,42,0.18))]'></div>
            <div class='absolute inset-x-5 bottom-5 rounded-sm border border-white/16 bg-black/10 p-4'>
              <p class='text-xs font-semibold uppercase tracking-[0.26em] text-white/70'>Carfit Service</p>
              <h3 class='mt-2 text-xl font-semibold text-white'>{service.title}</h3>
            </div>
          </div>
          <div class='p-5'>
            <p class='text-sm leading-7 text-slate-600'>{service.description}</p>
          </div>
        </article>
      ))}
    </div>

    <div class='mt-14 bg-[var(--carfit-dark)] px-6 py-10 text-center text-white shadow-[0_26px_60px_rgba(2,6,23,0.18)] sm:px-8'>
      <h3 class='mt-4 text-3xl font-semibold sm:text-4xl'>Jetzt Angebot einholen</h3>
      <a
        href='#online-anfrage'
        class='mt-6 inline-flex items-center rounded-md bg-[var(--carfit-accent)] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[var(--carfit-accent-strong)]'
      >
        Hier Preis anfragen
      </a>
    </div>
  </div>
</section>
