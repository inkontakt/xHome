---
import ReviewsGallery from '../../../new/astro-reviews-package/src/components/ReviewsGallery.astro'
import { getCarfitSqliteReviews, getCarfitSqliteReviewStats } from '@/lib/carfit-sqlite-reviews'

const reviews = getCarfitSqliteReviews(100, 0)
const stats = getCarfitSqliteReviewStats()
---

<section class='bg-white py-14 sm:py-18'>
  <div class='mx-auto max-w-6xl px-4 sm:px-6 lg:px-8'>
    <div class='mx-auto max-w-3xl text-center'>
      <p class='text-xs font-semibold uppercase tracking-[0.24em] text-[var(--carfit-accent)]'>
        SQLite Reviews
      </p>
      <h2 class='mt-4 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl'>
        Kundenbewertungen aus der lokalen Datenbank
      </h2>
      <p class='mx-auto mt-4 max-w-2xl text-sm leading-7 text-slate-600 sm:text-base'>
        Diese Ansicht rendert die WP-Social-Ninja-Bewertungen direkt aus dem lokalen Export.
      </p>
    </div>

    <div class='carfit-sqlite-reviews mt-8'>
      <ReviewsGallery
        reviews={reviews}
        stats={stats}
        showHeader={true}
        showGoogleLogo={true}
        showLoadMore={true}
        itemsPerPage={6}
        headerTitle='Google Bewertungen'
        loadMoreLabel='Mehr Laden'
        contentLanguage='original'
      />
    </div>
  </div>
</section>

<style>
  .carfit-sqlite-reviews :global(.reviews-gallery) {
    --review-star-filled: #f5b301;
    --review-star-empty: #e5e7eb;
    --review-text: #475569;
    --review-muted: #64748b;
    --review-card-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    --review-btn-bg: var(--carfit-accent);
    --carfit-review-card-height: 340px;
    max-width: none;
    padding-inline: 0;
    padding-bottom: 0;
  }

  .carfit-sqlite-reviews :global(.reviews-header) {
    padding-top: 0;
  }

  .carfit-sqlite-reviews :global(.reviews-header__title),
  .carfit-sqlite-reviews :global(.reviewer-name a),
  .carfit-sqlite-reviews :global(.reviewer-name span) {
    color: #0f172a;
  }

  .carfit-sqlite-reviews :global(.review-card) {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    min-height: var(--carfit-review-card-height);
    height: var(--carfit-review-card-height);
  }

  .carfit-sqlite-reviews :global(.review-info) {
    flex: 1 1 auto;
    min-height: 0;
    width: 100%;
  }

  .carfit-sqlite-reviews :global(.review-text) {
    flex: 1 1 auto;
    min-height: 0;
    max-height: 140px;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding-right: 0.35rem;
    scrollbar-width: thin;
    scrollbar-color: #cbd5e1 transparent;
    width: 100%;
  }

  .carfit-sqlite-reviews :global(.review-text::-webkit-scrollbar) {
    width: 6px;
  }

  .carfit-sqlite-reviews :global(.review-text::-webkit-scrollbar-track) {
    background: transparent;
  }

  .carfit-sqlite-reviews :global(.review-text::-webkit-scrollbar-thumb) {
    background-color: #cbd5e1;
    border-radius: 9999px;
  }

  .carfit-sqlite-reviews :global(.reviews-load-more:hover) {
    background-color: var(--carfit-accent-strong);
    opacity: 1;
  }

  @media (max-width: 639px) {
    .carfit-sqlite-reviews :global(.review-card) {
      min-height: 320px;
      height: 320px;
    }

    .carfit-sqlite-reviews :global(.review-text) {
      max-height: 124px;
    }
  }
</style>
