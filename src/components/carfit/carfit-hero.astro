---
import { Clock3, MapPin, PhoneCall } from 'lucide-react'

import { carfitContact } from '@/components/carfit/carfit-data'

const contactItems = [
  {
    icon: PhoneCall,
    label: carfitContact.phoneLabel,
    lines: [`Telefon: ${carfitContact.phoneDisplay}`],
    href: carfitContact.phoneHref
  },
  {
    icon: MapPin,
    label: carfitContact.addressLabel,
    lines: carfitContact.addressLines,
    href: carfitContact.addressHref
  },
  {
    icon: Clock3,
    label: carfitContact.hoursLabel,
    lines: carfitContact.hoursLines,
    href: '#online-anfrage'
  }
]
---

<section id='home' class='relative -mt-16 overflow-hidden bg-[var(--carfit-dark)] pt-16 text-white'>
  <div class='absolute inset-0 bg-[linear-gradient(90deg,rgba(14,22,36,0.96)_0%,rgba(14,22,36,0.93)_42%,rgba(14,22,36,0.76)_70%,rgba(22,34,51,0.82)_100%)]'></div>
  <div class='absolute inset-y-0 right-0 hidden w-[48%] bg-[radial-gradient(circle_at_68%_36%,rgba(115,163,255,0.24),transparent_10%),radial-gradient(circle_at_78%_42%,rgba(255,255,255,0.16),transparent_6%),linear-gradient(180deg,rgba(22,34,51,0.38),rgba(22,34,51,0.64))] lg:block'></div>
  <div class='absolute bottom-5 right-[12%] hidden h-56 w-96 rounded-[50%] border border-white/8 bg-[linear-gradient(180deg,#1d2634_0%,#0b1220_100%)] opacity-80 shadow-[0_24px_70px_rgba(0,0,0,0.4)] lg:block'></div>

  <div class='relative mx-auto max-w-6xl px-4 pb-18 pt-10 sm:px-6 lg:px-8 lg:pb-28 lg:pt-18'>
    <div class='max-w-xl'>
      <div class='mb-4 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em] text-white/70'>
        CARFIT Hamburg Codex
      </div>
      <h1 class='max-w-md text-4xl font-semibold leading-tight sm:text-5xl lg:text-6xl'>
        Carfit Fahrzeugaufbereitung Hamburg
      </h1>
      <p class='mt-4 max-w-lg text-lg font-medium text-sky-100/90 sm:text-xl'>
        Alles aus einer Hand. Alles aus Hamburg. Alles von Carfit.
      </p>
      <p class='mt-4 max-w-lg text-sm leading-7 text-white/72 sm:text-base'>
        Kratzer, Dellen, Flecken oder unangenehme Gerüche sind nicht Probleme, sondern unsere tägliche
        Herausforderung.
      </p>
      <div class='mt-8 flex flex-wrap items-center gap-4'>
        <a
          href='#online-anfrage'
          class='inline-flex items-center rounded-md bg-[var(--carfit-accent)] px-5 py-3 text-sm font-semibold text-white shadow-[0_10px_30px_rgba(56,86,214,0.32)] transition hover:translate-y-[-1px] hover:bg-[var(--carfit-accent-strong)]'
        >
          Hier Preis anfragen
        </a>
        <a href={carfitContact.phoneHref} class='text-sm font-medium text-white/80 transition hover:text-white'>
          Telefon: {carfitContact.phoneDisplay}
        </a>
      </div>
    </div>
  </div>

  <div class='relative z-10 mx-auto -mt-10 max-w-6xl px-4 pb-8 sm:px-6 lg:px-8'>
    <div class='grid gap-4 rounded-[1.1rem] border border-slate-200 bg-white p-5 text-slate-900 shadow-[0_20px_48px_rgba(0,0,0,0.14)] sm:grid-cols-3 sm:p-6'>
      {contactItems.map(item => {
        const Icon = item.icon

        return (
          <a href={item.href} class='group flex items-start gap-4 rounded-xl px-2 py-2 transition hover:bg-slate-50'>
            <span class='mt-0.5 inline-flex size-11 shrink-0 items-center justify-center rounded-full bg-[var(--carfit-light)] text-[#0284c7]'>
              <Icon className='size-5' />
            </span>
            <span>
              <span class='block text-sm font-semibold text-slate-900'>{item.label}</span>
              {item.lines.map(line => (
                <span class='block text-sm leading-6 text-slate-600'>{line}</span>
              ))}
            </span>
          </a>
        )
      })}
    </div>
    <p class='mt-3 text-center text-[11px] font-medium tracking-[0.14em] text-slate-500 uppercase'>
      {carfitContact.directions}
    </p>
  </div>
</section>
