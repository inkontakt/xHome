---
import '../styles/reviews.css';
import ReviewCard from './ReviewCard.astro';
import type { Review, ReviewStats } from '../types/review.js';

interface Props {
  reviews: Review[];
  stats?: ReviewStats | null;
  itemsPerPage?: number;
  showHeader?: boolean;
  /** Show multicolour Google “G” beside the header title when the header is visible. Default: true. */
  showGoogleLogo?: boolean;
  showLoadMore?: boolean;
  headerTitle?: string;
  excerptMaxChars?: number;
  loadMoreLabel?: string;
  readMoreLabel?: string;
}

const {
  reviews,
  stats = null,
  itemsPerPage = 9,
  showHeader = true,
  showGoogleLogo = true,
  showLoadMore = true,
  headerTitle = 'Google Reviews',
  excerptMaxChars = 200,
  loadMoreLabel = 'Load more',
  readMoreLabel = 'Read more',
} = Astro.props;

const galleryUid = `reviews-gallery-${reviews[0]?.id ?? 'x'}-${reviews.length}`;
const displayStats = stats && stats.totalReviews > 0;
const headerStars = displayStats ? Math.round(stats.avgRating) : 0;
const showLoadMoreBtn = showLoadMore && reviews.length > itemsPerPage;
---

<div class="reviews-gallery" id={galleryUid}>
  {
    showHeader && displayStats && (
      <header class="reviews-header">
        <div class="reviews-header__heading-row">
          {
            showGoogleLogo && (
              <svg
                class="reviews-header__google-logo"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 48 48"
                width="28"
                height="28"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  fill="#FFC107"
                  d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"
                />
                <path
                  fill="#FF3D00"
                  d="m6.306 14.691 6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"
                />
                <path
                  fill="#4CAF50"
                  d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"
                />
                <path
                  fill="#1976D2"
                  d="M43.611 20.083H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C42.023 37.357 44 34.052 44 24c0-1.341-.138-2.65-.389-3.917z"
                />
              </svg>
            )
          }
          <h2 class="reviews-header__title">{headerTitle}</h2>
        </div>
        <div class="reviews-header__stats">
          <span class="reviews-header__avg">{stats.avgRating.toFixed(1)}</span>
          <ul class="reviews-header__stars" aria-hidden="true">
            {[0, 1, 2, 3, 4].map((i) => (
              <li class:list={['star', i < headerStars ? 'star--filled' : 'star--empty']}>
                <svg viewBox="0 0 24 24" width="18" height="18" focusable="false">
                  <path d="M12 2.5l2.8 5.7 6.3.9-4.5 4.4 1.1 6.3L12 17.9 5.3 19.8l1.1-6.3L1.9 9.1l6.3-.9L12 2.5z" />
                </svg>
              </li>
            ))}
          </ul>
          <span class="reviews-header__count">Based on {stats.totalReviews} reviews</span>
        </div>
      </header>
    )
  }

  <div class="reviews-grid" role="list">
    {
      reviews.map((review, i) => (
        <div
          class:list={['review-card-wrap', { 'review-card-wrap--hidden': i >= itemsPerPage }]}
          data-review-index={i}
          role="listitem"
        >
          <ReviewCard review={review} excerptMaxChars={excerptMaxChars} readMoreLabel={readMoreLabel} />
        </div>
      ))
    }
  </div>

  {
    showLoadMoreBtn && (
      <div class="reviews-footer">
        <button type="button" class="reviews-load-more" id={`${galleryUid}-load-more`}>
          {loadMoreLabel}
        </button>
      </div>
    )
  }
</div>

{
  showLoadMoreBtn && (
    <script define:vars={{ galleryUid, itemsPerPage }}>
      const root = document.getElementById(galleryUid);
      const btn = document.getElementById(`${galleryUid}-load-more`);
      if (root && btn) {
        const wraps = root.querySelectorAll('.review-card-wrap');
        let visible = itemsPerPage;
        btn.addEventListener('click', () => {
          visible += itemsPerPage;
          wraps.forEach((el, i) => {
            if (i < visible) el.classList.remove('review-card-wrap--hidden');
          });
          if (visible >= wraps.length) btn.style.display = 'none';
        });
      }
    </script>
  )
}
